{
  "name": "codex-whatsapp-bridge",
  "version": "0.1.0",
  "description": "Minimal local WhatsApp bridge for controlling Codex through Easyhook.",
  "type": "module",
  "bin": {
    "codex-whatsapp": "./bin/codex-whatsapp.js"
  },
  "scripts": {
    "start": "node ./bin/codex-whatsapp.js start",
    "start:tunnel": "node ./bin/codex-whatsapp.js start --tunnel",
    "check": "node --check ./bin/codex-whatsapp.js"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
